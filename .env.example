# Copy this to .env and fill in values

# Database — for local docker-compose use the values below as-is
DATABASE_URL=postgresql+asyncpg://webhookrecon:webhookrecon@localhost:5432/webhookrecon

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Webhook signature secret — must match the secret configured in your payment provider
WEBHOOK_SECRET=change_me_to_a_strong_random_secret

# Environment: development | staging | production
APP_ENV=development

# Comma-separated allowed origins (only used when APP_ENV != development)
# CORS_ORIGINS=["https://your-frontend.com"]
